#!/usr/bin/env bash
# Runs the test suites before allowing a commit. Blocks the commit if either fails.
#
# One-time setup (per clone): git config core.hooksPath .githooks

set -e
cd "$(git rev-parse --show-toplevel)"

echo "pre-commit: running hid_ui.js compliance tests..."
node test_hid_ui.js

echo "pre-commit: running hid_parser.py unit tests..."
python3 -m unittest test_hid_parser.py

echo "pre-commit: all tests passed."
